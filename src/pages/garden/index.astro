---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('garden');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Digital Garden | Bryce Roberts">
  <section class="page-header">
    <div class="header-content fade-in-up">
      <h1>Digital Garden</h1>
      <div class="divider"></div>
      <p class="subtitle">Thoughts, patch notes, and technical deep dives.</p>
    </div>
  </section>

  <section class="posts-list">
    {posts.map((post, index) => {
      const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });
      return (
        <a href={`/garden/${post.id}`} class="post-item glass-card fade-in-up" style={`animation-delay: ${0.1 * (index + 1)}s;`}>
          <div class="post-meta">
            <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
            <div class="tags">
              {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </a>
      )
    })}
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 4rem;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    color: var(--text-bright);
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--text-main);
    margin-top: 1.5rem;
  }

  .divider {
    height: 3px;
    width: 60px;
    background: var(--accent);
    border-radius: 2px;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-item {
    display: block;
    text-decoration: none;
    cursor: pointer;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-main);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent);
  }

  .post-item h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text-bright);
    transition: color 0.2s ease;
  }

  .post-item:hover h2 {
    color: var(--accent);
  }

  .post-item p {
    color: var(--text-main);
    margin: 0;
  }

  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
