---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('garden');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Format date
const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={`${post.data.title} | Bryce Roberts`}>
  <article class="garden-post fade-in-up">
    <a href="/garden" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to garden
    </a>

    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="meta">
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        <div class="tags">
          {post.data.tags?.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    <div class="prose glass-card">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
    color: var(--text-bright);
    letter-spacing: -0.02em;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-main);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent);
  }

  .prose {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-main);
  }

  .prose :global(h2) {
    font-size: 1.75rem;
    color: var(--text-bright);
    margin: 2rem 0 1rem;
  }
  
  .prose :global(h3) {
    font-size: 1.4rem;
    color: var(--text-bright);
    margin: 1.5rem 0 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(ul) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .prose :global(pre) {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid var(--card-border);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
