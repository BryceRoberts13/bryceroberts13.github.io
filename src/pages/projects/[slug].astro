---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Format date
const formattedDate = new Date(project.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout title={`${project.data.title} | Bryce Roberts`}>
  <article class="project-post fade-in-up">
    <a href="/projects" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to projects
    </a>

    <header class="post-header">
      <h1>{project.data.title}</h1>
      <div class="meta">
        <time datetime={project.data.date.toISOString()}>{formattedDate}</time>
        <div class="tags">
          {project.data.tags?.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
      {(project.data.github || project.data.link) && (
        <div class="external-links">
          {project.data.github && <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="glass-btn">GitHub</a>}
          {project.data.link && <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="glass-btn">Live View</a>}
        </div>
      )}
    </header>

    <div class="prose glass-card">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
    color: var(--text-bright);
    letter-spacing: -0.02em;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text-main);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent);
  }

  .external-links {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .glass-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 6px;
    color: var(--text-bright);
    font-size: 0.9rem;
    transition: all 0.2s ease;
    backdrop-filter: blur(10px);
  }

  .glass-btn:hover {
    background: rgba(252, 170, 45, 0.1);
    border-color: rgba(252, 170, 45, 0.4);
    color: var(--accent);
  }

  .prose {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-main);
  }

  .prose :global(h2) {
    font-size: 1.75rem;
    color: var(--text-bright);
    margin: 2rem 0 1rem;
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(ul) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
